		draw_line(b.head(2),c.head(2),0xffffffff);
		draw_line(c.head(2),a.head(2),0xffffffff);*/

		// g1.transform(rotateMat);

		g1.renderGeo();
		b1.render();
		fundm::updateTransMat();
		// draw();
		show();
		SDL_Delay(1000 / 24.0);
	}
