void viewTUpdate() {
	viewMat << 1, 0, 0, -camera.pos[0], 0, 1, 0, -camera.pos[1], 0, 0, 1,
	    -camera.pos[2], 0, 0, 0, 1;
	Eigen::Matrix4d Rview;
	// 自计算right方向
	camera.right.block<3, 1>(0, 0) =
	    camera.lookat.head<3>().cross(camera.upwards.head<3>());

	Rview << camera.right[0], camera.right[1], camera.right[2], 0,
	    camera.upwards[0], camera.upwards[1], camera.upwards[2], 0,
	    -camera.lookat[0], -camera.lookat[1], -camera.lookat[2], 0, 0, 0, 0, 1;
	viewMat = Rview * viewMat;
}
