void Event() {
	while (true) {
		if (SDL_PollEvent(&event)) {
			if (event.type == SDL_EVENT_QUIT)
				break;
			switch (event.type) {
			case SDL_EVENT_KEY_DOWN:
				// SDL_Log("%d", event.key.key);
				if (event.key.key == SDLK_W)
					camera.pos += camera.lookat * camSpeed;
				if (event.key.key == SDLK_S)
					camera.pos -= camera.lookat * camSpeed;
				if (event.key.key == SDLK_A)
					camera.pos -= camera.right * camSpeed;
				if (event.key.key == SDLK_D)
					camera.pos += camera.right * camSpeed;
				if (event.key.key == SDLK_SPACE)
					camera.pos += camera.upwards * camSpeed;
				if (event.key.key == SDLK_LSHIFT)
					camera.pos -= camera.upwards * camSpeed;
				if (event.key.key == SDLK_1)
					b1.setShading(
					    render_func::geometryR::shading_mode::FLAT_SHADING);
				if (event.key.key == SDLK_2)
					b1.setShading(
					    render_func::geometryR::shading_mode::GOURAUD_SHADING);
				if (event.key.key == SDLK_3)
					b1.setShading(
					    render_func::geometryR::shading_mode::PHONG_SHADING);
				if (event.key.key == SDLK_LEFT)
					b1.move(Eigen::Vector4d(-boxspeed, 0, 0, 0));
				if (event.key.key == SDLK_RIGHT)
					b1.move(Eigen::Vector4d(boxspeed, 0, 0, 0));
				if (event.key.key == SDLK_UP)
					b1.move(Eigen::Vector4d(0, 0, -boxspeed, 0));
				if (event.key.key == SDLK_DOWN)
					b1.move(Eigen::Vector4d(0, 0, boxspeed, 0));
				break;
			default:
				break;
			}
		}
		viewTUpdate();
		Clear();

		/*a = t*a;b=t*b;c=t*c;
		a = mz*a;
		b= mz*b;
		c= mz*c;
